# Copy to .env and fill in. NEVER commit .env.
# Generate secrets with: openssl rand -hex 32

DATABASE_URL=postgresql://cukurmap:CHANGE_ME@localhost:5432/cukurmap?schema=public
PORT=3000

# JWT signing secret (openssl rand -hex 32)
JWT_SECRET=CHANGE_ME

# Pepper for hashing device IDs before storage (openssl rand -hex 32)
DEVICE_PEPPER=CHANGE_ME


# Vote thresholds
FIXED_THRESHOLD=5
HIDE_THRESHOLD=3
