# Prod env — kopyala: cp .env.prod.example .env.prod ve doldur. ASLA commit'leme.
# Secret üretimi: openssl rand -hex 32

POSTGRES_USER=cukurmap
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=cukurmap

# API container'ın host'ta bind edeceği loopback portu (Plesk nginx buraya proxy'ler)
API_PORT=3000

JWT_SECRET=CHANGE_ME
DEVICE_PEPPER=CHANGE_ME
ADMIN_TOKEN=CHANGE_ME

FIXED_THRESHOLD=5
HIDE_THRESHOLD=3

# Bilgi amaçlı — Plesk'te bu domain için subdomain + Let's Encrypt + reverse proxy kurulur
DOMAIN=api.EXAMPLE.com
